@model List<HQTCSDL.Controllers.BookingViewModel>

@{
    ViewData["PageTitle"] = "Tổng quan";
    ViewData["CurrentPage"] = "dashboard";
    
    var activeBookings = Model.Count(b => b.Status == "active");
    var totalBookings = Model.Count;
    var pendingCheckIns = Model.Count(b => b.Status == "booked");
}

<div style="display: flex; flex-direction: column; height: 100%; gap: 1.5rem;">
    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-label">Sân đang hoạt động</div>
            <div class="stat-value primary">@activeBookings</div>
            <div class="stat-subtitle">@totalBookings tổng cộng</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Lịch đặt hôm nay</div>
            <div class="stat-value warning">@totalBookings</div>
            <div class="stat-subtitle">Đặt sân</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Khách sắp đến</div>
            <div class="stat-value primary">@pendingCheckIns</div>
            <div class="stat-subtitle">Cần xác nhận</div>
        </div>
    </div>

    <!-- Scroll Area -->
    <div class="scroll-area" style="flex: 1; padding: 1.5rem;">
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            @if (pendingCheckIns > 0)
            {
                <!-- Pending Check-ins Card -->
                <div class="card" style="border-left: 4px solid var(--color-warning);">
                    <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Chờ Check In</h3>
                    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                        @foreach (var booking in Model.Where(b => b.Status == "Đã xác nhận"))
                        {
                            <div style="display: flex; align-items: center; justify-content: space-between; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border-color);">
                                <div>
                                    <p style="font-weight: 500; margin: 0;">@booking.CustomerName</p>
                                    <p style="font-size: 0.875rem; color: var(--color-gray-600); margin: 0;">
                                        @booking.CourtName - @booking.StartTime
                                    </p>
                                </div>
                                <span class="badge badge-warning">Sắp bắt đầu</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Recent Activity Card -->
            <div class="card">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">Hoạt động gần đây</h3>
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    @foreach (var booking in Model)
                    {
                        <div style="display: flex; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                            <div>
                                <p style="font-weight: 500; margin: 0;">@booking.CustomerName</p>
                                <p style="font-size: 0.875rem; color: var(--color-gray-600); margin: 0;">
                                    @booking.CourtName - @booking.StartTime
                                </p>
                            </div>
                            <div style="display: flex; gap: 0.5rem;">
                                <!-- Booking Status Badge -->
                                @if (booking.Status == "Đang sử dụng")
                                {
                                    <span class="badge badge-primary">@booking.Status</span>
                                }
                                else if (booking.Status == "Hoàn thành")
                                {
                                    <span class="badge badge-success">@booking.Status</span>
                                }
                                else if (booking.Status == "Đã hủy")
                                {
                                    <span class="badge badge-danger">@booking.Status</span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">@booking.Status</span>
                                }

                                <!-- Payment Status Badge -->
                                @if (booking.PaymentStatus == "paid-online")
                                {
                                    <span class="badge badge-primary">✓ Đã thanh toán</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Stats Removed -->
        </div>
    </div>
</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Update time every second
        setInterval(() => {
            const now = new Date();
            const options = { 
                weekday: 'long', 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            };
            document.getElementById('currentDateTime').textContent = 
                now.toLocaleDateString('vi-VN', options);
        }, 1000);
    </script>
}
