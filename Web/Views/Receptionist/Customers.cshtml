@model List<HQTCSDL.Controllers.CustomerViewModel>

@{
    ViewData["PageTitle"] = "Quản lý khách hàng";
    ViewData["CurrentPage"] = "customers";
}

<div style="display: flex; flex-direction: column; gap: 1.5rem; height: 100%;">
    <!-- Header with Actions -->
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-size: 1.5rem; font-weight: bold;">Quản lý khách hàng</h2>
        <button class="btn btn-primary" onclick="openAddCustomerModal()">
            <i class="fas fa-user-plus" style="margin-right: 0.5rem;"></i>
            Thêm khách hàng
        </button>
    </div>

    <!-- Filter Bar -->
    <div class="card" style="padding: 1rem;">
        <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 250px;">
                <input type="text" class="input" placeholder="Tìm kiếm theo tên, SĐT, CCCD..." id="customerSearch" />
            </div>
            
            <select class="input" style="flex: 0 0 180px;" id="memberTypeFilter">
                <option value="">Tất cả loại thành viên</option>
                <option value="platinum">Platinum</option>
                <option value="gold">Gold</option>
                <option value="silver">Silver</option>
                <option value="student">Sinh viên</option>
                <option value="general">Thường</option>
            </select>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="card" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
        <div style="padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
            <h3 style="font-size: 1.125rem; font-weight: 600; margin: 0;">
                Tổng số: <span id="totalCustomers">@Model.Count</span> khách hàng
            </h3>
        </div>

        <div class="scroll-area" style="flex: 1;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Mã KH</th>
                        <th>Họ và tên</th>
                        <th>Số điện thoại</th>
                        <th>Email</th>
                        <th>Ngày sinh</th>
                        <th>CCCD</th>
                        <th>Loại thành viên</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="customersTableBody">
                    @foreach (var customer in Model)
                    {
                        var memberBadge = customer.MemberType switch
                        {
                            "platinum" => "badge-primary",
                            "gold" => "badge-warning",
                            "silver" => "badge-outline",
                            "student" => "badge-success",
                            _ => "badge-outline"
                        };

                        var memberText = customer.MemberType switch
                        {
                            "platinum" => "💎 Platinum",
                            "gold" => "🥇 Gold",
                            "silver" => "🥈 Silver",
                            "student" => "🎓 Sinh viên",
                            _ => "👤 Thường"
                        };

                        <tr data-customer-id="@customer.Id">
                            <td style="font-weight: 600;">#@customer.Id</td>
                            <td>
                                <div style="font-weight: 500;">@customer.Name</div>
                            </td>
                            <td>@customer.Phone</td>
                            <td>@(customer.Email ?? "-")</td>
                            <td>@(customer.DateOfBirth?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@(customer.CCCD ?? "-")</td>
                            <td>
                                <span class="badge @memberBadge">
                                    @memberText
                                </span>
                            </td>
                            <td>
                                <div style="display: flex; gap: 0.5rem;">
                                    <button class="btn btn-outline" style="padding: 0.25rem 0.75rem; font-size: 0.75rem;"
                                            onclick="viewCustomerDetail('@customer.Id')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn btn-outline" style="padding: 0.25rem 0.75rem; font-size: 0.75rem;"
                                            onclick="editCustomer('@customer.Id')">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn btn-ghost" style="padding: 0.25rem 0.5rem; color: var(--color-primary);"
                                            onclick="upgradeCustomer('@customer.Id')">
                                        <i class="fas fa-arrow-up"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Customer Stats -->
    <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem;">
        <div class="card" style="text-align: center; padding: 1rem;">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--color-primary);">
                @Model.Count(c => c.MemberType == "platinum")
            </div>
            <div style="font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.25rem;">
                💎 Platinum
            </div>
        </div>
        <div class="card" style="text-align: center; padding: 1rem;">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--color-warning);">
                @Model.Count(c => c.MemberType == "gold")
            </div>
            <div style="font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.25rem;">
                🥇 Gold
            </div>
        </div>
        <div class="card" style="text-align: center; padding: 1rem;">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--color-gray-600);">
                @Model.Count(c => c.MemberType == "silver")
            </div>
            <div style="font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.25rem;">
                🥈 Silver
            </div>
        </div>
        <div class="card" style="text-align: center; padding: 1rem;">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--color-success);">
                @Model.Count(c => c.MemberType == "student")
            </div>
            <div style="font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.25rem;">
                🎓 Sinh viên
            </div>
        </div>
        <div class="card" style="text-align: center; padding: 1rem;">
            <div style="font-size: 1.5rem; font-weight: bold; color: var(--color-gray-700);">
                @Model.Count(c => c.MemberType == "general")
            </div>
            <div style="font-size: 0.875rem; color: var(--color-gray-600); margin-top: 0.25rem;">
                👤 Thường
            </div>
        </div>
    </div>
</div>

<!-- Add Customer Dialog -->
<partial name="~/Views/Shared/Components/_AddCustomerDialog.cshtml" />

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('customerSearch').addEventListener('input', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('#customersTableBody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
            
            updateCustomersCount();
        });

        // Member type filter
        document.getElementById('memberTypeFilter').addEventListener('change', function() {
            const filterValue = this.value.toLowerCase();
            const rows = document.querySelectorAll('#customersTableBody tr');
            
            rows.forEach(row => {
                if (!filterValue) {
                    row.style.display = '';
                } else {
                    const badge = row.querySelector('td:nth-child(7) .badge');
                    const badgeText = badge ? badge.textContent.toLowerCase() : '';
                    row.style.display = badgeText.includes(filterValue) ? '' : 'none';
                }
            });
            
            updateCustomersCount();
        });

        function updateCustomersCount() {
            const visibleRows = document.querySelectorAll('#customersTableBody tr[style=""]').length;
            const allRows = document.querySelectorAll('#customersTableBody tr:not([style*="display: none"])').length;
            document.getElementById('totalCustomers').textContent = visibleRows > 0 ? visibleRows : allRows;
        }

        function viewCustomerDetail(customerId) {
            // TODO: Open modal or navigate to detail page
            alert('Chi tiết khách hàng #' + customerId);
        }

        function editCustomer(customerId) {
            // TODO: Open edit modal
            alert('Chỉnh sửa khách hàng #' + customerId);
        }

        function upgradeCustomer(customerId) {
            if (confirm('Nâng cấp thành viên cho khách hàng #' + customerId + '?')) {
                // TODO: Send upgrade request
                alert('Chức năng đang phát triển');
            }
        }
    </script>
}
