@model List<DTO.DichVu>

@{
    ViewData["PageTitle"] = "POS/Dịch vụ";
    ViewData["CurrentPage"] = "pos";
    
    var loaiDichVu = Model.GroupBy(d => d.LoaiDichVu).ToDictionary(g => g.Key, g => g.ToList());
}

<div style="display: flex; flex-direction: column; gap: 1rem; height: 100%;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-size: 1.5rem; font-weight: bold; color: var(--color-gray-900);">POS/Dịch vụ</h2>
        
        <!-- Mode Switcher Removed -->

    </div>

    <div style="display: grid; grid-template-columns: 3fr 1fr; gap: 1rem; flex: 1; min-height: 0;">
        <!-- Products Area -->
        <div class="scroll-area" style="border-radius: var(--radius-lg); padding: 1rem;">
            @foreach (var category in loaiDichVu)
            {
                <div style="margin-bottom: 2rem;">
                    <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 1rem;">@category.Key</h3>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
                        @foreach (var dichVu in category.Value)
                        {
                            <div class="card" style="cursor: pointer; transition: box-shadow 0.2s; @(dichVu.SoLuongTonKho == 0 ? "opacity: 0.5; pointer-events: none;" : "")" 
                                 onclick="addToCart('@dichVu.MaDichVu', '@dichVu.TenDichVu', @dichVu.DonGia)">
                                <div style="margin-bottom: 0.75rem;">
                                    <h4 style="font-weight: 600; margin: 0;">@dichVu.TenDichVu</h4>
                                    <p style="font-size: 0.75rem; color: var(--color-gray-500); margin: 0.25rem 0 0 0;">
                                        @if (dichVu.SoLuongTonKho > 0)
                                        {
                                            <text>Còn lại: @dichVu.SoLuongTonKho</text>
                                        }
                                        else
                                        {
                                            <span style="color: var(--color-danger);">Hết hàng</span>
                                        }
                                    </p>
                                </div>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span style="font-size: 1.25rem; font-weight: bold; color: var(--color-primary);">@dichVu.DonGia.ToString("N0")₫</span>
                                    <button class="btn btn-primary" style="padding: 0.5rem;" @(dichVu.SoLuongTonKho == 0 ? "disabled" : "")>
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Cart Area -->
        <div class="card" style="display: flex; flex-direction: column; max-height: 100%;">
            <div style="padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                <h3 style="font-size: 1.125rem; font-weight: 600; margin: 0;">
                    <i class="fas fa-shopping-cart" style="margin-right: 0.5rem;"></i>
                    Giỏ hàng
                </h3>
            </div>

            <!-- Customer/Booking Selection -->
            <div style="padding: 1rem 0; border-bottom: 1px solid var(--border-color);">
                <!-- Booking Mode: Active Booking Selection -->
                <div id="bookingSelectionArea">
                    <label style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem;">
                        <i class="fas fa-futbol" style="margin-right: 0.25rem;"></i>
                        Chọn phiếu đặt đang sử dụng
                    </label>
                    <select class="input" id="activeBookingSelect">
                        <option value="">-- Chọn phiếu đặt --</option>
                    </select>
                    <div id="bookingInfo" style="margin-top: 0.75rem; padding: 0.75rem; background: var(--color-gray-50); border-radius: var(--radius-md); display: none;">
                        <div style="font-size: 0.875rem; color: var(--color-gray-700);">
                            <div style="margin-bottom: 0.25rem;"><strong>Khách:</strong> <span id="bookingCustomer"></span></div>
                            <div style="margin-bottom: 0.25rem;"><strong>Sân:</strong> <span id="bookingCourt"></span></div>
                            <div><strong>Check-in:</strong> <span id="bookingCheckin"></span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cart Items -->
            <div style="flex: 1; overflow-y: auto; padding: 1rem 0;" id="cartItems">
                <p style="text-align: center; color: var(--color-gray-500); font-size: 0.875rem;">
                    Giỏ hàng trống
                </p>
            </div>

            <!-- Cart Summary -->
            <div style="padding-top: 1rem; border-top: 1px solid var(--border-color);">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span style="color: var(--color-gray-600);">Tạm tính:</span>
                    <span id="subtotal">0₫</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span style="color: var(--color-gray-600);">Giảm giá:</span>
                    <span id="discount">0₫</span>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 1.125rem; font-weight: bold; margin-top: 1rem; padding-top: 1rem; border-top: 2px solid var(--border-color);">
                    <span>Tổng cộng:</span>
                    <span style="color: var(--color-primary);" id="total">0₫</span>
                </div>

                <!-- Booking Mode Button -->
                <button id="bookingAddBtn" class="btn btn-success" style="width: 100%; margin-top: 1rem; padding: 0.75rem;" onclick="addServicesToBooking()">
                    <i class="fas fa-plus-circle" style="margin-right: 0.5rem;"></i>
                    Thêm vào phiếu
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];
        let activeBookings = [];

        // Initialize - load active bookings
        document.addEventListener('DOMContentLoaded', function() {
            loadActiveBookings();
        });

        // Load Active Bookings
        function loadActiveBookings() {
            console.log('Loading active bookings...');
            fetch('/Receptionist/LayDanhSachPhieuDat?trangThai=' + encodeURIComponent('Đang sử dụng'))
                .then(response => {
                    console.log('Response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('API response:', data);
                    if (data.success) {
                        activeBookings = data.danhSach || [];
                        console.log('Active bookings loaded:', activeBookings.length);
                        renderActiveBookingsDropdown();
                    } else {
                        console.error('API returned error:', data.message);
                        activeBookings = [];
                        renderActiveBookingsDropdown();
                    }
                })
                .catch(error => {
                    console.error('Error loading active bookings:', error);
                    activeBookings = [];
                    renderActiveBookingsDropdown();
                });
        }

        // Render Active Bookings Dropdown
        function renderActiveBookingsDropdown() {
            const select = document.getElementById('activeBookingSelect');
            select.innerHTML = '<option value="">-- Chọn phiếu đặt --</option>';
            
            if (activeBookings.length === 0) {
                const option = document.createElement('option');
                option.value = '';
                option.textContent = 'Không có phiếu đặt nào đang sử dụng';
                option.disabled = true;
                select.appendChild(option);
                return;
            }
            
            activeBookings.forEach(booking => {
                const option = document.createElement('option');
                option.value = booking.maPhieuDat;
                const checkinTime = formatTimeSpan(booking.thoiGianCheckin);
                option.textContent = `[${booking.tenSan}] - ${booking.tenKhachHang} - ${checkinTime}`;
                select.appendChild(option);
            });
            
            // Add change event listener (only once)
            select.removeEventListener('change', handleBookingChange);
            select.addEventListener('change', handleBookingChange);
        }

        // Handle booking selection change
        function handleBookingChange(event) {
            updateBookingInfo(event.target.value);
        }

        // Update Booking Info Display
        function updateBookingInfo(maPhieuDat) {
            const bookingInfo = document.getElementById('bookingInfo');
            
            if (!maPhieuDat) {
                bookingInfo.style.display = 'none';
                return;
            }
            
            const booking = activeBookings.find(b => b.maPhieuDat === maPhieuDat);
            if (booking) {
                document.getElementById('bookingCustomer').textContent = booking.tenKhachHang || '--';
                document.getElementById('bookingCourt').textContent = booking.tenSan || '--';
                document.getElementById('bookingCheckin').textContent = formatTimeSpan(booking.thoiGianCheckin);
                bookingInfo.style.display = 'block';
            }
        }

        // Format TimeSpan from C# - can be "HH:mm:ss" or object format
        function formatTimeSpan(timeSpan) {
            if (!timeSpan) return '--';
            
            // If it's a string (HH:mm:ss format)
            if (typeof timeSpan === 'string') {
                return timeSpan.substring(0, 5); // Return HH:mm
            }
            
            // If it's an object with hours/minutes
            if (typeof timeSpan === 'object') {
                const hours = timeSpan.hours || 0;
                const minutes = timeSpan.minutes || 0;
                return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}`;
            }
            
            return '--';
        }

        function addToCart(id, name, price) {
            const existingItem = cart.find(item => item.id === id);
            
            if (existingItem) {
                existingItem.quantity++;
            } else {
                cart.push({ id, name, price, quantity: 1 });
            }
            
            updateCart();
        }

        function removeFromCart(id) {
            cart = cart.filter(item => item.id !== id);
            updateCart();
        }

        function updateQuantity(id, quantity) {
            if (quantity <= 0) {
                removeFromCart(id);
                return;
            }
            
            const item = cart.find(item => item.id === id);
            if (item) {
                item.quantity = quantity;
            }
            
            updateCart();
        }

        function updateCart() {
            const cartItemsDiv = document.getElementById('cartItems');
            
            if (cart.length === 0) {
                cartItemsDiv.innerHTML = '<p style="text-align: center; color: var(--color-gray-500); font-size: 0.875rem;">Giỏ hàng trống</p>';
            } else {
                cartItemsDiv.innerHTML = cart.map(item => `
                    <div style="padding: 0.75rem; border-bottom: 1px solid var(--border-color);">
                        <div style="display: flex; justify-content: space-between; align-items-start; margin-bottom: 0.5rem;">
                            <span style="font-weight: 500; flex: 1;">${item.name}</span>
                            <button onclick="removeFromCart('${item.id}')" style="color: var(--color-danger); background: none; border: none; cursor: pointer; padding: 0;">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <button onclick="updateQuantity('${item.id}', ${item.quantity - 1})" class="btn btn-outline" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">
                                    <i class="fas fa-minus"></i>
                                </button>
                                <span style="font-weight: 600; min-width: 20px; text-align: center;">${item.quantity}</span>
                                <button onclick="updateQuantity('${item.id}', ${item.quantity + 1})" class="btn btn-outline" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">
                                    <i class="fas fa-plus"></i>
                                </button>
                            </div>
                            <span style="font-weight: 600;">${(item.price * item.quantity).toLocaleString()}₫</span>
                        </div>
                    </div>
                `).join('');
            }
            
            // Update totals
            const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            const discount = 0; // TODO: Calculate based on customer membership
            const total = subtotal - discount;
            
            document.getElementById('subtotal').textContent = subtotal.toLocaleString() + '₫';
            document.getElementById('discount').textContent = discount.toLocaleString() + '₫';
            document.getElementById('total').textContent = total.toLocaleString() + '₫';
        }



        // Add Services to Booking
        async function addServicesToBooking() {
            if (cart.length === 0) {
                alert('Giỏ hàng trống!');
                return;
            }

            const maPhieuDat = document.getElementById('activeBookingSelect').value;
            if (!maPhieuDat) {
                alert('Vui lòng chọn phiếu đặt!');
                return;
            }

            const booking = activeBookings.find(b => b.maPhieuDat === maPhieuDat);
            const total = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);

            if (!confirm(`Thêm ${cart.length} dịch vụ (${total.toLocaleString()}₫) vào phiếu của ${booking.tenKhachHang}?`)) {
                return;
            }

            try {
                let successCount = 0;
                let errorMessages = [];

                // Add each service to the booking
                for (const item of cart) {
                    const response = await fetch('/Receptionist/ThemDichVu', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            MaPhieuDat: maPhieuDat,
                            MaDichVu: item.id,
                            SoLuong: item.quantity
                        })
                    });

                    const data = await response.json();
                    if (data.success) {
                        successCount++;
                    } else {
                        errorMessages.push(`${item.name}: ${data.message}`);
                    }
                }

                // Show results
                if (successCount === cart.length) {
                    alert(`✓ Đã thêm ${successCount} dịch vụ vào phiếu thành công!`);
                    cart = [];
                    updateCart();
                } else if (successCount > 0) {
                    alert(`Đã thêm ${successCount}/${cart.length} dịch vụ.\n\nLỗi:\n${errorMessages.join('\n')}`);
                    // Remove successful items from cart
                    cart = cart.filter(item => 
                        errorMessages.some(msg => msg.startsWith(item.name))
                    );
                    updateCart();
                } else {
                    alert(`Không thể thêm dịch vụ:\n${errorMessages.join('\n')}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi thêm dịch vụ!');
            }
        }
    </script>
}
