@model List<HQTCSDL.Controllers.BookingViewModel>

@{
    ViewData["PageTitle"] = "Lịch đặt sân";
    ViewData["CurrentPage"] = "schedule";
    
    var timeSlots = new List<string> { "07:00", "07:30", "08:00", "08:30", "09:00", "09:30", "10:00", "10:30", "11:00", "11:30", "12:00", "12:30", "13:00", "13:30", "14:00", "14:30", "15:00", "15:30", "16:00", "16:30", "17:00", "17:30", "18:00", "18:30", "19:00", "19:30", "20:00", "20:30", "21:00", "21:30", "22:00" };
    
    // Get courts from database via ViewBag
    var courts = ViewBag.Courts as List<HQTCSDL.Controllers.CourtViewModel> ?? new List<HQTCSDL.Controllers.CourtViewModel>();
    var selectedDate = ViewBag.SelectedDate as DateTime? ?? DateTime.Today;
}

<div style="display: flex; flex-direction: column; gap: 1.5rem; height: 100%;">
    <!-- Header with Date Navigation -->
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-size: 1.5rem; font-weight: bold;">Lịch đặt sân</h2>
        <div style="display: flex; gap: 1rem; align-items: center;">
            <button class="btn btn-outline" onclick="changeDate(-1)">
                <i class="fas fa-chevron-left"></i>
            </button>
            <div style="font-weight: 600; min-width: 200px; text-align: center;">
                <i class="fas fa-calendar-alt" style="margin-right: 0.5rem;"></i>
                <span id="currentDate">@selectedDate.ToString("dd/MM/yyyy")</span>
            </div>
            <button class="btn btn-outline" onclick="changeDate(1)">
                <i class="fas fa-chevron-right"></i>
            </button>
            <button class="btn btn-primary" onclick="openNewBookingDialog()">
                <i class="fas fa-plus" style="margin-right: 0.5rem;"></i>
                Đặt sân mới
            </button>
        </div>
    </div>

    <!-- Court Type Filter -->
    <div class="card" style="padding: 1rem;">
        <div style="display: flex; gap: 1rem; align-items: center;">
            <label style="font-weight: 600;">Loại sân:</label>
            <button class="btn btn-primary active" data-court-type="all" onclick="filterCourtType('all')">
                Tất cả
            </button>
            <button class="btn btn-outline" data-court-type="mini-football" onclick="filterCourtType('mini-football')">
                ⚽ Bóng đá Mini
            </button>
            <button class="btn btn-outline" data-court-type="tennis" onclick="filterCourtType('tennis')">
                🎾 Tennis
            </button>
            <button class="btn btn-outline" data-court-type="badminton" onclick="filterCourtType('badminton')">
                🏸 Cầu lông
            </button>
        </div>
    </div>

    <!-- Schedule Grid -->
    <div class="card" style="flex: 1; display: flex; flex-direction: column; min-height: 0; padding: 0;">
        <div class="scroll-area" style="flex: 1; overflow-x: auto;">
            <div style="min-width: 1400px;">
                <!-- Header Row - Time slots horizontal -->
                <div style="display: grid; grid-template-columns: 250px repeat(@timeSlots.Count, 64px);">
                    <div style="padding: 0.75rem; font-weight: 600; color: var(--color-gray-700); border-bottom: 1px solid var(--border-color); border-right: 1px solid var(--border-color); background-color: var(--color-gray-50); position: sticky; left: 0; z-index: 10; box-sizing: border-box;">
                        Sân
                    </div>
                    @foreach (var timeSlot in timeSlots)
                    {
                        <div style="padding: 0.75rem; text-align: center; font-weight: 500; color: var(--color-gray-600); border-bottom: 1px solid var(--border-color); background-color: var(--color-gray-50); font-size: 0.75rem; box-sizing: border-box;">
                            @timeSlot
                        </div>
                    }

                </div>

                <!-- Court Rows -->
                @foreach (var court in courts)
                {
                    <div style="display: grid; grid-template-columns: 250px repeat(@timeSlots.Count, 64px); border-bottom: 1px solid var(--border-color);">
                        <div style="padding: 0.75rem; font-weight: 500; color: var(--color-gray-700); border-right: 1px solid var(--border-color); background-color: var(--background); position: sticky; left: 0; z-index: 10; box-sizing: border-box;" data-court-type="@court.CourtType">
                            @court.TenSan
                        </div>
                        @for (var i = 0; i < timeSlots.Count; i++)
                        {
                            var timeSlot = timeSlots[i];
                            // FIX: Now comparing date, court name, and start time
                            var booking = Model.FirstOrDefault(b => 
                                b.BookingDate.Date == selectedDate.Date && 
                                b.CourtName == court.TenSan && 
                                b.StartTime == timeSlot);
                            
                            // Check if this slot is part of a previous booking (also check date)
                            var isPartOfPreviousBooking = Model.Any(b => {
                                if (b.BookingDate.Date != selectedDate.Date) return false;
                                if (b.CourtName != court.TenSan) return false;
                                var startIndex = timeSlots.IndexOf(b.StartTime);
                                var span = b.DurationMinutes / 30;
                                var endIndex = startIndex + span;
                                return i > startIndex && i < endIndex;
                            });
                            
                            if (isPartOfPreviousBooking)
                            {
                                continue;
                            }
                            
                            if (booking != null)
                            {
                                var span = booking.DurationMinutes / 30;
                                var bgColor = booking.Status == "active" ? "#dbeafe" : 
                                             booking.Status == "booked" ? "#fee2e2" : "#dcfce7";
                                var borderColor = booking.Status == "active" ? "#3b82f6" : 
                                                booking.Status == "booked" ? "#ef4444" : "#10b981";
                                var textColor = booking.Status == "active" ? "#1e40af" : 
                                              booking.Status == "booked" ? "#991b1b" : "#166534";
                                
                                <div style="grid-column: span @span; min-height: 48px; padding: 0.5rem; border-left: 2px solid @borderColor; background-color: @bgColor; color: @textColor; cursor: pointer; transition: opacity 0.2s; box-sizing: border-box;"
                                     data-court-type="@court.CourtType"
                                     onclick="viewBookingDetail('@booking.Id')"
                                     onmouseover="this.style.opacity='0.8'"
                                     onmouseout="this.style.opacity='1'">
                                    <div style="font-size: 0.875rem; font-weight: 600;">@booking.CustomerName</div>
                                    <div style="font-size: 0.75rem; margin-top: 0.25rem;">
                                        @(booking.PaymentStatus == "paid-online" ? "✓ Đã thanh toán" : "⏳ Chưa thanh toán")
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div style="min-height: 48px; padding: 0.5rem; border-left: 1px solid var(--border-color); background-color: var(--background); cursor: pointer; transition: background-color 0.2s; box-sizing: border-box;"
                                     data-court-type="@court.CourtType"
                                     onclick="quickBook('@selectedDate.ToString("yyyy-MM-dd")', '@timeSlot', '@court.MaSan', '@court.TenSan')"
                                     onmouseover="this.style.backgroundColor='var(--color-gray-50)'"
                                     onmouseout="this.style.backgroundColor='var(--background)'">
                                    <div style="font-size: 0.75rem; color: var(--color-gray-400); text-align: center;">Trống</div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Legend -->
        <div style="padding: 1rem; border-top: 1px solid var(--border-color); display: flex; gap: 2rem; background-color: var(--color-gray-50);">
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 16px; height: 16px; background-color: var(--background); border: 2px solid #9ca3af; border-radius: 2px;"></div>
                <span style="font-size: 0.875rem; color: var(--color-gray-600);">Còn trống</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 16px; height: 16px; background-color: #fee2e2; border: 2px solid #ef4444; border-radius: 2px;"></div>
                <span style="font-size: 0.875rem; color: var(--color-gray-600);">Đã đặt</span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="width: 16px; height: 16px; background-color: #dbeafe; border: 2px solid #3b82f6; border-radius: 2px;"></div>

<!-- Include Modal -->
<partial name="_BookingDetailModal" />
                <span style="font-size: 0.875rem; color: var(--color-gray-600);">Đang diễn ra</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/receptionist/new-booking-dialog.js"></script>
    <script src="~/js/receptionist/booking-detail.js"></script>
    <script>
        // Initialize with the date from the server
        let selectedDate = new Date('@selectedDate.ToString("yyyy-MM-dd")');

        function formatDateForUrl(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function changeDate(days) {
            selectedDate.setDate(selectedDate.getDate() + days);
            document.getElementById('currentDate').textContent = selectedDate.toLocaleDateString('vi-VN');
            
            // Reload schedule for the new date
            const dateStr = formatDateForUrl(selectedDate); // Format: YYYY-MM-DD
            window.location.href = `/Receptionist/Schedule?date=${dateStr}`;
        }

        function filterCourtType(courtType) {
            // Update button states
            document.querySelectorAll('[data-court-type]').forEach(btn => {
                if (btn.tagName === 'BUTTON') {
                    btn.classList.remove('btn-primary', 'active');
                    btn.classList.add('btn-outline');
                }
            });
            
            const activeBtn = document.querySelector(`button[data-court-type="${courtType}"]`);
            if (activeBtn) {
                activeBtn.classList.remove('btn-outline');
                activeBtn.classList.add('btn-primary', 'active');
            }

            // Filter courts
            document.querySelectorAll('[data-court-type]').forEach(cell => {
                if (cell.tagName !== 'BUTTON') {
                    if (courtType === 'all') {
                        cell.style.display = '';
                    } else {
                        cell.style.display = cell.getAttribute('data-court-type') === courtType ? '' : 'none';
                    }
                }
            });
        }

        function quickBook(dateStr, timeSlot, courtId, courtName) {
            // Chuyển định dạng ngày hiển thị cho đẹp
            const dateParts = dateStr.split('-');
            const displayDate = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]}`;
            
            if (confirm(`Đặt sân ${courtName}\nThời gian: ${timeSlot} - Ngày: ${displayDate}?`)) {
                if (typeof openBookingWithDetails === 'function') {
                    openBookingWithDetails(dateStr, timeSlot, courtId);
                } else {
                    alert('Đang tải dữ liệu, vui lòng thử lại...');
                }
            }
        }

        // viewBookingDetail is handled in booking-detail.js

        function openNewBookingDialog() {
            document.getElementById('newBookingModal').style.display = 'flex';
            // Call the real implementation from new-booking-dialog.js
            if (typeof resetBookingForm === 'function') {
                resetBookingForm();
            }
            if (typeof showStep === 'function') {
                showStep(1);
            }
        }
    </script>
}
