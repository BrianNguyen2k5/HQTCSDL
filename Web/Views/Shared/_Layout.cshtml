<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData[index: "Title"] - VietSport</title>
	<link rel="shortcut icon" type="image/x-icon" href="~/favicon.ico?v=2" />
	<script type="importmap"></script>
	<script src="https://cdn.tailwindcss.com"></script>

	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

	<link rel="stylesheet" href="~/HQTCSDL.styles.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	
	@RenderSection("Styles", required: false)
</head>

<body>
	<header>
		<nav class="header-display">
			<div class="flex flex-row items-center gap-2">
				<img src="~/favicon.ico?v=2" alt="Logo" class="w-8 h-8">
				<a class="header-logo" asp-area="" asp-controller="Home" asp-action="Index">VietSport</a>
			</div>
			
			<div class="nav-items">
				<a class="underline font-bold text-[#777] hover:text-blue-500" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
				@if (User.IsInRole("Lễ tân"))
				{
					<a class="font-bold underline text-[#777] hover:text-blue-500" asp-area="" asp-controller="Receptionist" asp-action="Dashboard">Lễ tân</a>
				}
				@if (User.IsInRole("Quản lý"))
				{
					<a class="font-bold underline text-[#777] hover:text-blue-500" asp-area="" asp-controller="Employer" asp-action="Dashboard">Quản lý</a>
				}
				@if (User.IsInRole("Thu ngân"))
				{
					<a class="font-bold underline text-[#777] hover:text-blue-500" asp-area="" asp-controller="Cashier" asp-action="Bill">Thu ngân</a>
				}
				
				<!-- ... Tiếp tục thêm vào role của mn -->
			</div>

			@if (User.Identity.IsAuthenticated)
			{
				<a 
					class="white-button-decor flex items-center"
					asp-area="" 
					asp-controller="Auth" 
					asp-action="Logout"
				>
					<p class="flex items-center gap-2"><i class="bi bi-arrow-return-left"></i>Đăng xuất</p>
				</a>
			}
			else {
				<div class="flex items-center gap-2">
					<a 
						class="white-button-decor flex items-center"
						asp-area="" 
						asp-controller="Auth" 
						asp-action="Register"
					>
						<p class="flex items-center gap-2"><i class="bi bi-arrow-return-left"></i>Đăng ký</p>
					</a>
					<a 
						class="blue-button-decor flex items-center"
						asp-area="" 
						asp-controller="Auth" 
						asp-action="Login"
					>
						<p class="flex items-center gap-2"><i class="bi bi-arrow-return-left"></i>Đăng nhập</p>
					</a>
				</div>
			}
			
		</nav>
	</header>

	<main role="main" class="mt-20 text-center pb-10">
		@RenderBody()
	</main>

	<footer>
		<div class="">
			&copy; 2025 - HQTCSDL - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
		</div>
	</footer>

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	
	@await RenderSectionAsync("Scripts", required: false)
</body>

</html>