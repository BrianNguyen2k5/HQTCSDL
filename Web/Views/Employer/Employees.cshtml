@{
    ViewData["Title"] = "Quản lý nhân viên";
    Layout = "_EmployerLayout";

    var employees = new[] {
        new {
            id = 1,
            code = "NV001",
            name = "Nguyễn Văn A",
            dob = "1995-05-15",
            gender = "Nam",
            idNumber = "0123456789",
            address = "123 Đường Lê Lợi, Hà Nội",
            phone = "0912345678",
            position = "Lễ tân",
            salary = 5000000,
            branch = "Hà Nội",
        },
        new {
            id = 2,
            code = "NV002",
            name = "Trần Thị B",
            dob = "1998-03-20",
            gender = "Nữ",
            idNumber = "0987654321",
            address = "456 Đường Hàng Bài, Hà Nội",
            phone = "0987654321",
            position = "Thu ngân",
            salary = 5500000,
            branch = "Hà Nội",
        },
        new {
            id = 3,
            code = "NV003",
            name = "Phạm Văn C",
            dob = "1992-07-10",
            gender = "Nam",
            idNumber = "0112233445",
            address = "789 Đường Nguyễn Huệ, TP.HCM",
            phone = "0945123456",
            position = "Kỹ thuật",
            salary = 6000000,
            branch = "TP.HCM",
        },
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/Employer/Dashboard.css" />
}

@section Scripts {
    <script src="~/js/Employer/Dashboard.js" asp-append-version="true"></script>
    <script>
        function handleAction() {
            alert("Chức năng đang phát triển");
        }

        function filterEmployees() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById("searchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("employeeTable");
            tr = table.getElementsByTagName("tr");

            for (i = 0; i < tr.length; i++) {
                // Search by Code (0), Name (1), or Phone (4)
                var tdCode = tr[i].getElementsByTagName("td")[0];
                var tdName = tr[i].getElementsByTagName("td")[1];
                var tdPhone = tr[i].getElementsByTagName("td")[4];

                if (tdCode || tdName || tdPhone) {
                    var txtCode = tdCode ? tdCode.textContent || tdCode.innerText : "";
                    var txtName = tdName ? tdName.textContent || tdName.innerText : "";
                    var txtPhone = tdPhone ? tdPhone.textContent || tdPhone.innerText : "";

                    if (txtCode.toUpperCase().indexOf(filter) > -1 || 
                        txtName.toUpperCase().indexOf(filter) > -1 || 
                        txtPhone.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                    } else {
                        tr[i].style.display = "none";
                    }
                }       
            }
        }
    </script>
}

<div class="p-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-foreground">Quản lý nhân viên</h1>
        </div>
        <button onclick="handleAction()" class="flex items-center gap-2 bg-primary text-primary-foreground px-4 py-2 rounded-lg hover:opacity-90 bg-blue-600 text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
            Thêm nhân viên
        </button>
    </div>

    <!-- Search -->
    <div class="mb-6 relative">
        <div class="absolute left-3 top-3 text-muted-foreground text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" x2="16.65" y1="21" y2="16.65"/></svg>
        </div>
        <input
            type="text"
            id="searchInput"
            onkeyup="filterEmployees()"
            placeholder="Tìm kiếm theo tên, mã nhân viên hoặc số điện thoại..."
            class="w-full pl-10 pr-4 py-2 bg-card border border-border rounded-lg text-foreground placeholder-gray-400 border-gray-200"
        />
    </div>

    <!-- Table -->
    <div class="bg-card border border-border rounded-lg overflow-x-auto bg-white shadow-sm">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border bg-accent bg-gray-50">
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Mã NV</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Họ tên</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Ngày sinh</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Giới tính</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Số ĐT</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Chức vụ</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Chi nhánh</th>
                    <th class="text-left py-3 px-4 font-medium text-card text-gray-700">Lương</th>
                    <th class="text-center py-3 px-4 font-medium text-card text-gray-700">Hành động</th>
                </tr>
            </thead>
            <tbody id="employeeTable">
                @foreach (var emp in employees)
                {
                    <tr class="border-b border-border hover:bg-gray-50">
                        <td class="py-3 px-4 text-foreground font-medium text-gray-900">@emp.code</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.name</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.dob</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.gender</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.phone</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.position</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.branch</td>
                        <td class="py-3 px-4 text-foreground text-gray-900">@emp.salary.ToString("N0")đ</td>
                        <td class="py-3 px-4 flex justify-center gap-2">
                            <button onclick="handleAction()" class="p-2 hover:bg-accent rounded hover:bg-gray-100" title="Xem chi tiết">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            </button>
                            <button onclick="handleAction()" class="p-2 hover:bg-accent rounded hover:bg-gray-100" title="Sửa">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </button>
                            <button onclick="handleAction()" class="p-2 hover:bg-accent rounded hover:bg-gray-100" title="Xóa">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
