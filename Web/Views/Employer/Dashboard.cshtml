@{
    ViewData["Title"] = "Employer Dashboard";
    Layout = "_EmployerLayout";

    var stats = new[] {
        new { label = "Doanh thu tháng này", value = "45.2M", icon = "dollar", trend = "+12%" },
        new { label = "Nhân viên hoạt động", value = "24", icon = "users", trend = "+2" },
        new { label = "Ca trực tuần này", value = "168", icon = "calendar", trend = "100%" },
        new { label = "Tỷ lệ sử dụng sân", value = "78%", icon = "trending", trend = "+5%" },
    };

    var bookings = new[] {
        new { id = 1, court = "Sân bóng đá mini 1", time = "14:00-15:30", customer = "Nguyễn Minh Đức", status = "Đang sử dụng" },
        new { id = 2, court = "Sân cầu lông 2", time = "15:00-16:00", customer = "Trần Thị Hương", status = "Đã thanh toán" },
        new { id = 3, court = "Sân tennis 1", time = "16:00-18:00", customer = "Phạm Hoàng", status = "Chờ thanh toán" },
        new { id = 4, court = "Sân futsal 3", time = "18:00-19:30", customer = "Đội bóng ABA", status = "Đã thanh toán" },
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/Employer/Dashboard.css" />
}

<div class="p-8">
    <h1 class="text-3xl font-bold text-foreground mb-8">Dashboard</h1>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        @foreach (var stat in stats)
        {
            <div class="bg-card border border-border rounded-lg p-6 bg-white shadow-sm">
                <div class="flex items-start justify-between mb-4">
                    <div>
                        <p class="text-muted-foreground mb-1 text-gray-500">@stat.label</p>
                        <p class="text-2xl font-bold text-foreground text-gray-900">@stat.value</p>
                    </div>
                    @if (stat.icon == "dollar")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary text-blue-600"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    }
                    else if (stat.icon == "users")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary text-blue-600"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    }
                    else if (stat.icon == "calendar")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary text-blue-600"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                    }
                    else if (stat.icon == "trending")
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary text-blue-600"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                    }
                </div>
                <p class="text-primary text-blue-600">@stat.trend</p>
            </div>
        }
    </div>

    <!-- Bookings Table -->
    <div class="bg-card border border-border rounded-lg p-6 bg-white shadow-sm">
        <h2 class="text-lg font-semibold text-foreground mb-4 text-gray-900">Đơn đặt sân hôm nay</h2>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-border border-gray-200">
                        <th class="text-left py-3 px-4 text-muted-foreground font-medium text-gray-500">Sân</th>
                        <th class="text-left py-3 px-4 text-muted-foreground font-medium text-gray-500">Giờ</th>
                        <th class="text-left py-3 px-4 text-muted-foreground font-medium text-gray-500">Khách hàng</th>
                        <th class="text-left py-3 px-4 text-muted-foreground font-medium text-gray-500">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in bookings)
                    {
                        <tr class="border-b border-border border-gray-200 hover:bg-gray-50">
                            <td class="py-3 px-4 text-foreground text-gray-900">@booking.court</td>
                            <td class="py-3 px-4 text-foreground text-gray-900">@booking.time</td>
                            <td class="py-3 px-4 text-foreground text-gray-900">@booking.customer</td>
                            <td class="py-3 px-4">
                                @{
                                    var statusClass = "";
                                    if (booking.status == "Đang sử dụng") statusClass = "bg-blue-500 text-white";
                                    else if (booking.status == "Đã thanh toán") statusClass = "bg-green-500 text-white";
                                    else statusClass = "bg-yellow-500 text-gray-900";
                                }
                                <span class="inline-block px-3 py-1 rounded font-medium @statusClass">
                                    @booking.status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Employer/Dashboard.js" asp-append-version="true"></script>
}