@{
    ViewData["Title"] = "Phân công ca trực";
    Layout = "_EmployerLayout";

    var shifts = new[] {
        new {
            id = 1,
            date = "2024-11-21",
            shift = "Sáng (6:00-14:00)",
            employees = new[] { "Nguyễn Văn A", "Trần Thị B" },
            branch = "Hà Nội",
        },
        new {
            id = 2,
            date = "2024-11-21",
            shift = "Chiều (14:00-22:00)",
            employees = new[] { "Phạm Văn C", "Lê Thị D" },
            branch = "Hà Nội",
        },
        new {
            id = 3,
            date = "2024-11-22",
            shift = "Sáng (6:00-14:00)",
            employees = new[] { "Nguyễn Văn A", "Phạm Văn C" },
            branch = "TP.HCM",
        },
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/Employer/Dashboard.css" />
		<link rel ="stylesheet" href="~/css/Employer/Arrangement.css" />
}

@section Scripts {
    <script src="~/js/Employer/Dashboard.js" asp-append-version="true"></script>
    <script>
        function handleAction() {
            alert("Chức năng đang phát triển");
        }
    </script>
}

<div class="p-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-foreground">Phân công ca trực</h1>
        <button
            onclick="handleAction()"
            class="blue-button-decor flex items-center gap-2"
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
            Phân công ca
        </button>
    </div>

    <!-- Filter by date -->
    <div class="mb-6 flex gap-4">
        <div class="relative flex-1 max-w-xs">
            <div class="absolute left-3 top-3 text-muted-foreground text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
            <input
                type="date"
                class="w-full pl-10 pr-4 py-2 bg-card border border-border rounded-lg text-foreground border-gray-200"
            />
        </div>
    </div>

    <!-- Shifts List -->
    <div class="employees-arrangement-list">
        @foreach (var shift in shifts)
        {
            <div class="bg-card border border-border rounded-lg p-6 shadow-sm h-full flex flex-col justify-between">

                <div class="flex items-start justify-between mb-4">
                    <div class="text-left">
                        <p class="text-sm text-muted-foreground mb-1 text-gray-500">@shift.date</p>
                        <h3 class="text-lg font-semibold text-foreground text-gray-900">@shift.shift</h3>
                        <p class="text-sm text-muted-foreground mt-1 text-gray-500">@shift.branch</p>
                    </div>
                    <div class="flex gap-2">
                        <button
                            onclick="handleAction()"
                            class="p-2 hover:bg-accent rounded transition-colors hover:bg-gray-100"
                            title="Sửa ca trực"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary text-blue-600"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button
                            onclick="handleAction()"
                            class="p-2 hover:bg-accent rounded transition-colors hover:bg-gray-100"
                            title="Xóa ca trực"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-red-500"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                        </button>
                    </div>
                </div>
                <div class="space-y-2">
                    <p class="text-left text-muted-foreground text-gray-500">Nhân viên được phân công:</p>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var emp in shift.employees)
                        {
                            <span class="bg-primary/20 text-primary px-3 py-1 rounded-full text-sm bg-blue-100 text-blue-600">
                                @emp
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>