@model List<DTO.CoSo>

@{
	Layout = "_EmployerLayout";
}

@section Styles {
	<link rel="stylesheet" href="~/css/Employer/Dashboard.css" />
	<link rel="stylesheet" href="~/css/Employer/Report.css" />
}

<script>
	let flag = 1;

	function switchReportSubtab(subtab) {
		const revenueTabButton = document.getElementById('revenue-report-subtab-button');
		const statisticsTabButton = document.getElementById('cancel-list-subtab-button');
		const revenueSubtab = document.getElementById('revenue-report-subtab');
		const statisticsSubtab = document.getElementById('cancel-list-subtab');

		if (subtab === 'revenue-report') {
			flag = 1;
			revenueTabButton.disabled = true;
			statisticsTabButton.disabled = false;

			revenueTabButton.classList.add('blue-button-decor');
			statisticsTabButton.classList.remove('blue-button-decor');

			revenueSubtab.classList.remove('hidden');
			statisticsSubtab.classList.add('hidden');

		} else if (subtab === 'statistics-report') {
			flag = 2;
			revenueTabButton.disabled = false;
			statisticsTabButton.disabled = true;

			statisticsTabButton.classList.add('blue-button-decor');
			revenueTabButton.classList.remove('blue-button-decor');

			statisticsSubtab.classList.remove('hidden');
			revenueSubtab.classList.add('hidden');
		}
	}
</script>

<div id="tab-content-report" class="text-left p-8">
	<div class="subtab-button flex flex-row gap-8">
		<button 
			id="revenue-report-subtab-button" 
			class="blue-button-decor"
			onclick="switchReportSubtab('revenue-report')"
		>
			Báo cáo doanh thu
		</button>
		<button 
			id="cancel-list-subtab-button" 
			class=""
			onclick="switchReportSubtab('statistics-report')"
		>
			Thống kê phiếu
		</button>
	</div>
	<hr class="my-4" />

	<div id="revenue-report-subtab">
		<p class="title">Báo cáo doanh thu</p>
		<div class="revenue-report mt-2">
			<div class="date-picker-group">
				<select id="dp_year" name="NamSinh" class="dp-select">
					<option value="">Năm</option>
				</select>

				<select id="dp_month" name="ThangSinh" class="dp-select" disabled>
					<option value="">Tháng</option>
				</select>

				<select id="dp_day" name="NgaySinh" class="dp-select" disabled>
					<option value="">Ngày</option>
				</select>

				<button type="button" onclick="loadRevenue()" class="blue-button-decor">Xem Doanh Thu</button>

			</div>
			<div class="mt-4">
				<h3>Tổng doanh thu: <span id="lblDoanhThu" class="text-success font-bold">0 VNĐ</span></h3>
			</div>
		</div>

		<p class="title mt-8">Báo cáo doanh thu theo cơ sở</p>
		<div class="statistics-report mt-2">
			<div class="date-picker-group">
				<select id="dp_co_so" name="NamSinh" class="dp-select">
					<option value="">Cơ sở</option>
					@foreach (var item in Model)
					{
						<option value="@item.MaCoSo">@item.MaCoSo - @item.TenCoSo</option>
					}
				</select>
				<select id="dp_coso_year" name="NamSinh" class="dp-select">
					<option value="">Năm</option>
				</select>
				<button type="button" onclick="loadRevenueByCoSo()" id="btn_load_revenue_by_co_so"
					class="blue-button-decor">Xem Doanh Thu</button>
			</div>
		</div>

		<div id="revenue-detail-modal" class="modal hidden">
			<div class="modal-content">
				<p class="close-button text-right font-bold text-2xl" onclick="closeRevenueDetailModal()">
					&times;
				</p>
				<p class="text-xl font-bold mb-4 text-center">Chi tiết doanh thu</p>
				<div class="modal-header mt-8">
					<p>Số lượng hóa đơn: <span id="totalBillCount"></span></p>
					<p>Tổng doanh thu: <span id="totalBillRevenue"></span></p>
				</div>
				<div id="revenue-detail-content" class="mt-2">
				</div>
			</div>
		</div>
	</div>

	<div id="cancel-list-subtab" class="hidden">
		<p class="title mt-5">Thống kê phiếu</p>
		<div class="statistics-report mt-2">
			<p>Tổng số lượt đặt sân: <span id="San_total"></span></p>
			<p>Tổng số lượt đặt dịch vụ: <span id="DichVu_total"></span></p>
			<p>Tổng số lượt đặt tài sản: <span id="TaiSan_total"></span></p>
			<p>Tổng số lần phiếu đặt bị hủy: <span id="San_cancel"></span></p>
			
		</div>

		<p class="title mt-8">Báo cáo phiếu hủy theo năm</p>
		<div 
			class="mt-2 flex flex-row items-center 
					gap-4 border-1 border-gray-300 p-4 border-radius-20 shadow-lg
					border rounded-[20px]"
		>
			<select id="dp_cancel_year" name="" class="dp-select">
				<option value="">Năm</option>
			</select>
			<button class="blue-button-decor w-fit" onclick="handleServiceCancelModal()">
				Xem danh sách phiếu hủy
			</button>
		</div>

		<div id="service-cancel-modal" class="modal hidden">
			<div class="modal-content">
				<p class="close-button text-right font-bold text-2xl" onclick="closeServiceCancelModal()">
					&times;
				</p>
				<p class="text-xl font-bold mb-4 text-center">Chi tiết phiếu hủy</p>
				<div class="modal-header mt-8">
					<p>Số lượng phiếu bị hủy: <span id="total-cancellations"></span></p>
				</div>
				<div id="cancellation-list" class="mt-2">
				</div>
			</div>
		</div>

		<div id="field-renting-list">
		</div>
	</div>
</div>


@section Scripts {
	<script src="~/js/Employer/Dashboard.js" asp-append-version="true"></script>
	<script src="~/js/Employer/Report.js" asp-append-version="true"></script>
}