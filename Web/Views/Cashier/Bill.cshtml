@{
    ViewData["Title"] = "Thu Ngân - VietSport";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/cashier.css">
</head>
<body>
    <div id="app" class="flex h-screen bg-gray-100 overflow-hidden font-sans">
        
        <!-- Sidebar Navigation -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h1 class="sidebar-title">VietSport</h1>
                <p class="sidebar-subtitle">Giao diện thu ngân</p>
            </div>

            <nav class="sidebar-nav">
                <button class="nav-button active">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                    <span>Hóa Đơn</span>
                </button>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <div class="user-avatar">N</div>
                    <div class="user-details">
                        <div class="user-name">Nhân viên</div>
                        <div class="user-role">Thu ngân</div>
                    </div>
                </div>
                <button id="logoutButton" class="logout-button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                        <polyline points="16 17 21 12 16 7"></polyline>
                        <line x1="21" y1="12" x2="9" y2="12"></line>
                    </svg>
                    Đăng Xuất
                </button>
            </div>
        </div>

        <!-- Main Content Area -->
        <div class="main-content">
            
            <!-- Mobile Header -->
            <header class="mobile-header">
                <div class="mobile-title">VietSport</div>
                <button class="mobile-menu-button">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M12 1v6m0 6v6"></path>
                    </svg>
                </button>
            </header>

            <!-- View Content -->
            <div class="view-content">
                
                <!-- LIST VIEW -->
                <div id="listView" class="list-view">
                    <div class="page-header">
                        <div class="breadcrumb">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                            </svg>
                            <span>@(ViewBag.TenCoSo ?? "Cơ sở")</span>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </div>
                        <h1 class="page-title">Danh Sách Hóa Đơn</h1>
                    </div>

                    <!-- Filters Bar -->
                    <div class="filters-bar">
                        <div class="search-box">
                            <input type="text" 
                                   id="searchInput" 
                                   placeholder="Tìm kiếm tên khách hàng, số điện thoại, mã hóa đơn..." 
                                   class="search-input">
                            <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="11" cy="11" r="8"></circle>
                                <path d="m21 21-4.35-4.35"></path>
                            </svg>
                        </div>
                        
                        <div class="filter-tabs">
                            <button class="filter-tab active" data-filter="ALL">Tất cả</button>
                            <button class="filter-tab" data-filter="PENDING">Chưa thanh toán</button>
                            <button class="filter-tab" data-filter="PAID">Đã thanh toán</button>
                        </div>
                    </div>

                    <!-- Table Layout -->
                    <div class="table-container">
                        <table class="invoice-table">
                            <thead>
                                <tr>
                                    <th>Mã HĐ</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày lập</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-right">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="invoiceTableBody">
                                <tr>
                                    <td colspan="6" class="loading-cell">
                                        <div class="loading-spinner"></div>
                                        Đang tải dữ liệu...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <div class="table-footer">
                        <span id="invoiceCount">Đang tải...</span>
                    </div>
                </div>

                <!-- DETAIL VIEW -->
                <div id="detailView" class="detail-view" style="display: none;">
                    <div class="detail-container">
                        
                        <!-- Navigation -->
                        <div class="detail-header">
                            <button id="backButton" class="back-button">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="19" y1="12" x2="5" y2="12"></line>
                                    <polyline points="12 19 5 12 12 5"></polyline>
                                </svg>
                            </button>
                            <div>
                                <h1 class="detail-title">Chi Tiết Hóa Đơn</h1>
                                <p class="detail-subtitle" id="invoiceId"></p>
                            </div>
                            <div class="detail-actions">
                                <button class="print-button">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="6 9 6 2 18 2 18 9"></polyline>
                                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                                        <rect x="6" y="14" width="12" height="8"></rect>
                                    </svg>
                                    In Hóa Đơn
                                </button>
                            </div>
                        </div>

                        <div class="detail-content">
                            
                            <!-- Status Banner -->
                            <div id="statusBanner" class="status-banner">
                                <div class="status-text">TRẠNG THÁI: <span id="statusText"></span></div>
                                <div class="status-date" id="statusDate"></div>
                            </div>

                            <div class="detail-body">
                                <!-- Grid Layout -->
                                <div class="detail-grid">
                                    
                                    <!-- Left Column: Customer & Field -->
                                    <div class="detail-left">
                                        
                                        <!-- Customer -->
                                        <section class="detail-section">
                                            <h3 class="section-title">Khách Hàng</h3>
                                            <div class="customer-card" id="customerInfo">
                                                <!-- Populated by JavaScript -->
                                            </div>
                                        </section>

                                        <!-- Field Info -->
                                        <section class="detail-section">
                                            <h3 class="section-title">Thông Tin Đặt Sân</h3>
                                            <div class="field-info-grid" id="fieldInfo">
                                                <!-- Populated by JavaScript -->
                                            </div>
                                        </section>

                                        <!-- Services List -->
                                        <section class="detail-section">
                                            <h3 class="section-title">Chi Tiết Dịch Vụ</h3>
                                            <table class="service-table" id="serviceTable">
                                                <!-- Populated by JavaScript -->
                                            </table>
                                        </section>

                                    </div>

                                    <!-- Right Column: Summary -->
                                    <div class="detail-right">
                                        <div class="payment-card">
                                            <h3 class="payment-title">Thanh Toán</h3>
                                            
                                            <div class="payment-summary" id="paymentSummary">
                                                <!-- Populated by JavaScript -->
                                            </div>

                                            <button id="paymentButton" class="payment-button" style="display: none;">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                                                    <line x1="1" y1="10" x2="23" y2="10"></line>
                                                </svg>
                                                Thanh Toán Ngay
                                            </button>
                                            
                                            <div id="paidBadge" class="paid-badge" style="display: none;">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                                </svg>
                                                Đã Thanh Toán
                                            </div>

                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <!-- Payment Modal -->
    <div id="paymentModal" class="modal" style="display: none;">
        <div class="modal-overlay"></div>
        <div class="modal-content">
            
            <!-- Header -->
            <div class="modal-header">
                <div class="modal-header-bg"></div>
                <h3 class="modal-title">Xác Nhận Thanh Toán</h3>
                <p class="modal-invoice-id" id="modalInvoiceId"></p>
                <div class="modal-total" id="modalTotal"></div>
                
                <button id="closeModal" class="modal-close">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
            </div>

            <!-- Content -->
            <div class="modal-body">
                <p class="payment-method-label">Chọn phương thức</p>
                
                <div class="payment-methods">
                    <button class="payment-method active" data-method="Tiền mặt">
                        <div class="payment-method-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                        </div>
                        <div class="payment-method-text">
                            <div class="payment-method-name">Tiền mặt</div>
                            <div class="payment-method-desc">Thanh toán tại quầy</div>
                        </div>
                        <div class="payment-method-check">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                    </button>

                    <button class="payment-method" data-method="Ví điện tử">
                        <div class="payment-method-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                                <line x1="1" y1="10" x2="23" y2="10"></line>
                            </svg>
                        </div>
                        <div class="payment-method-text">
                            <div class="payment-method-name">Ví điện tử</div>
                            <div class="payment-method-desc">VietQR, Momo, ZaloPay</div>
                        </div>
                        <div class="payment-method-check">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button id="cancelPayment" class="modal-button-cancel">Đóng</button>
                <button id="confirmPayment" class="modal-button-confirm">Hoàn tất thanh toán</button>
            </div>
        </div>
    </div>

    <script src="~/js/cashier.js"></script>
</body>
</html>
